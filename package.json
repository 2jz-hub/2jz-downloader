{
  "name": "2jz-media-downloader",
  "version": "1.5.9",
  "description": "Media downloader CLI -- YouTube, Instagram, TikTok, Twitter/X, Reddit, SoundCloud, Vimeo, Twitch and 1000+ sites. Powered by yt-dlp with a rich interactive TUI.",
  "type": "module",
  "bin": {
    "2jz": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18 --clean --define.APP_VERSION=\"\\\"$npm_package_version\\\"\"",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/downloader.test.ts test/platform.test.ts test/config.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "postinstall": "node scripts/postinstall.mjs || true"
  },
  "keywords": [
    "downloader",
    "media-downloader",
    "youtube",
    "youtube-downloader",
    "instagram",
    "twitter",
    "tiktok",
    "reddit",
    "soundcloud",
    "vimeo",
    "twitch",
    "tumblr",
    "yt-dlp",
    "cli",
    "tui",
    "terminal",
    "video",
    "audio",
    "2jz",
    "termux"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/2jz-hub/2jz-downloader.git"
  },
  "bugs": {
    "url": "https://github.com/2jz-hub/2jz-downloader/issues"
  },
  "homepage": "https://github.com/2jz-hub/2jz-downloader#readme",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "execa": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
